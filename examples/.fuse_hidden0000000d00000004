<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Studio UX — Exemplo: Painel (Desktop)</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3/dist/tabler-icons.min.css">
  <link rel="stylesheet" href="../packages/tokens/tokens.css">
  <link rel="stylesheet" href="../packages/components/components.css">
  <style>
    /* Só composição/layout — todos os VALORES vêm de tokens (P1, P22). */
    body { margin: 0; background: var(--su-surface-base); font-family: var(--su-font-ui); color: var(--su-text-primary); }
    .shell { display: flex; min-height: 100vh; }
    .main { flex: 1; min-width: 0; display: flex; flex-direction: column; }
    .content { padding: var(--su-space-6); display: flex; flex-direction: column; gap: var(--su-space-6); }
    .page-title { font-size: var(--su-text-h2); font-weight: var(--su-fw-semibold); margin: 0; }
    .kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--su-space-3); }
    .delta-up { color: var(--su-success-fg); font-size: 12px; } .delta-down { color: var(--su-danger-fg); font-size: 12px; }
    .bars { display: flex; align-items: flex-end; gap: var(--su-space-2); height: 150px; }
    .bar { flex: 1; background: var(--su-action-tint); border-radius: 5px 5px 0 0; }
    .bar--peak { background: var(--su-action); }
    .field-search { display: flex; align-items: center; gap: 8px; border: 1px solid var(--su-border-default); border-radius: var(--su-radius-md); padding: 6px 10px; color: var(--su-text-muted); font-size: 12px; }
  </style>
</head>
<body class="su">
  <div class="shell">
    <!-- Sidebar -->
    <aside class="su-sidebar">
      <div class="su-sidebar__brand"><span style="width:22px;height:22px;border-radius:7px;background:var(--su-action);color:#fff;display:inline-flex;align-items:center;justify-content:center;"><i class="ti ti-square-rounded"></i></span>Studio UX</div>
      <nav class="su-nav">
         <a class="su-nav__item su-nav__item--active" href="dashboard.html"><i class="ti ti-layout-dashboard" style="font-size:18px;"></i>Painel</a>
        <a class="su-nav__item" href="clientes.html"><i class="ti ti-users" style="font-size:18px;"></i>Clientes</a>
        <a class="su-nav__item"><i class="ti ti-file-invoice" style="font-size:18px;"></i>Faturas</a>
        <a class="su-nav__item" href="analytics.html"><i class="ti ti-chart-bar" style="font-size:18px;"></i>Relatórios</a>
        <a class="su-nav__item"><i class="ti ti-settings" style="font-size:18px;"></i>Ajustes</a>
      </nav>
      <div class="su-sidebar__footer" style="display:flex;align-items:center;gap:9px;">
        <span style="width:28px;height:28px;border-radius:50%;background:var(--su-surface-sunken);display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;color:var(--su-text-secondary);">RM</span>
        <span style="line-height:1.25;flex:1;"><span style="display:block;font-size:12px;font-weight:500;">Robson</span><span style="display:block;font-size:11px;color:var(--su-text-muted);">Administrador</span></span>
        <i class="ti ti-logout" style="color:var(--su-text-muted);"></i>
      </div>
      <div style="padding:0 12px 12px;text-align:center;font-size:10px;color:var(--su-text-muted);">v1.0.0</div>
    </aside>

    <!-- Main -->
    <div class="main">
      <header class="su-topbar">
        <div style="flex:1;">
          <div class="su-breadcrumb">Início <span>/</span> Painel</div>
          <div style="font-size:16px;font-weight:600;">Painel</div>
        </div>
        <span class="field-search"><i class="ti ti-search"></i>Buscar</span>
        <button class="su-iconbtn" aria-label="Alternar tema" onclick="var h=document.documentElement;h.dataset.theme=h.dataset.theme==='dark'?'light':'dark';"><i class="ti ti-moon"></i></button>
        <button class="su-btn su-btn--primary"><i class="ti ti-plus"></i>Nova fatura</button>
      </header>

      <div class="content">
        <section class="kpis">
          <div class="su-statcard"><div class="su-statcard__label">Receita do mês</div><div class="su-statcard__value">R$ 148.230</div><div class="delta-up"><i class="ti ti-arrow-up-right"></i> 8,4%</div></div>
          <div class="su-statcard"><div class="su-statcard__label">Clientes ativos</div><div class="su-statcard__value">1.902</div><div class="delta-up"><i class="ti ti-arrow-up-right"></i> 1,2%</div></div>
          <div class="su-statcard"><div class="su-statcard__label">Ticket médio</div><div class="su-statcard__value">R$ 64</div><div class="delta-down"><i class="ti ti-arrow-down-right"></i> 1,2%</div></div>
          <div class="su-statcard"><div class="su-statcard__label">Inadimplência</div><div class="su-statcard__value">3,1%</div><div class="delta-down"><i class="ti ti-arrow-down-right"></i> 0,4%</div></div>
        </section>

        <section class="su-card">
          <div style="display:flex;align-items:center;margin-bottom:16px;"><span style="font-size:14px;font-weight:600;flex:1;">Receita por mês</span><span style="font-size:12px;color:var(--su-text-muted);">2026</span></div>
          <div class="bars">
            <div class="bar" style="height:52%;"></div><div class="bar" style="height:64%;"></div><div class="bar" style="height:48%;"></div>
            <div class="bar" style="height:72%;"></div><div class="bar" style="height:60%;"></div><div class="bar bar--peak" style="height:88%;"></div>
            <div class="bar" style="height:70%;"></div><div class="bar" style="height:80%;"></div>
          </div>
        </section>

        <section class="su-table-card">
          <div style="display:flex;align-items:center;padding:12px 16px;border-bottom:1px solid var(--su-border-subtle);"><span style="font-size:14px;font-weight:600;flex:1;">Faturas recentes</span><a style="font-size:12px;color:var(--su-action);text-decoration:none;">Ver todas</a></div>
          <table class="su-table">
            <thead><tr><th>Cliente</th><th>Status</th><th class="num">Valor</th><th class="num">Vencimento</th></tr></thead>
            <tbody>
              <tr><td>Marina Alves</td><td><span class="su-badge su-badge--success">Paga</span></td><td class="num">R$ 320</td><td class="num">12/07</td></tr>
              <tr><td>Carlos Nogueira</td><td><span class="su-badge su-badge--warning">Pendente</span></td><td class="num">R$ 540</td><td class="num">18/07</td></tr>
              <tr><td>Bianca Ferraz</td><td><span class="su-badge su-badge--danger">Vencida</span></td><td class="num">R$ 210</td><td class="num">02/07</td></tr>
              <tr><td>Diego Prado</td><td><span class="su-badge su-badge--success">Paga</span></td><td class="num">R$ 880</td><td class="num">10/07</td></tr>
            </tbody>
          </table>
        </section>
      </div>
    </div>
  </div>
</body>
</html>
