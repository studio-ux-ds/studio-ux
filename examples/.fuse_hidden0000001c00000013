<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Studio UX — Exemplo: Clientes (CRUD + Wizard, Desktop)</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3/dist/tabler-icons.min.css">
  <link rel="stylesheet" href="../packages/tokens/tokens.css">
  <link rel="stylesheet" href="../packages/components/components.css">
  <style>
    body { margin: 0; background: var(--su-surface-base); font-family: var(--su-font-ui); color: var(--su-text-primary); }
    .shell { display: flex; min-height: 100vh; }
    .main { flex: 1; min-width: 0; display: flex; flex-direction: column; }
    .content { padding: var(--su-space-6); }
    .toolbar { display: flex; align-items: center; gap: var(--su-space-3); padding: var(--su-space-3) var(--su-space-4); }
    .bulkbar { display: none; align-items: center; gap: var(--su-space-5); padding: var(--su-space-3) var(--su-space-4); background: var(--su-action-tint); font-size: 12px; }
    .bulkbar .act { display: inline-flex; align-items: center; gap: 5px; color: var(--su-action); cursor: pointer; }
    .bulkbar .act.dz { color: var(--su-danger-fg); }
    .row-menu { position: relative; }
    .row-menu .su-menu { display: none; position: absolute; top: 30px; right: 0; z-index: 30; }
    .row-menu.open .su-menu { display: block; }
    .field-search { display: flex; align-items: center; gap: 8px; border: 1px solid var(--su-border-default); border-radius: var(--su-radius-md); padding: 6px 10px; color: var(--su-text-muted); font-size: 12px; }
    .selrow td { background: color-mix(in srgb, var(--su-action) 5%, transparent); }
    .hidden { display: none !important; }
    .form-page { max-width: 780px; }
    .form-head { display: flex; align-items: center; gap: var(--su-space-3); margin-bottom: var(--su-space-5); }
    .pane { display: none; } .pane.on { display: block; }
    textarea.su-input { height: auto; padding: var(--su-space-3); resize: vertical; min-height: 72px; }
  </style>
</head>
<body class="su">
  <div class="shell">
    <aside class="su-sidebar">
      <div class="su-sidebar__brand"><span style="width:22px;height:22px;border-radius:7px;background:var(--su-action);color:#fff;display:inline-flex;align-items:center;justify-content:center;"><i class="ti ti-square-rounded"></i></span>Studio UX</div>
      <nav class="su-nav">
         <a class="su-nav__item" href="dashboard.html"><i class="ti ti-layout-dashboard" style="font-size:18px;"></i>Painel</a>
        <a class="su-nav__item su-nav__item--active" href="clientes.html"><i class="ti ti-users" style="font-size:18px;"></i>Clientes</a>
        <a class="su-nav__item"><i class="ti ti-file-invoice" style="font-size:18px;"></i>Faturas</a>
        <a class="su-nav__item" href="analytics.html"><i class="ti ti-chart-bar" style="font-size:18px;"></i>Relatórios</a>
        <a class="su-nav__item"><i class="ti ti-settings" style="font-size:18px;"></i>Ajustes</a>
      </nav>
      <div class="su-sidebar__footer" style="display:flex;align-items:center;gap:9px;">
        <span style="width:28px;height:28px;border-radius:50%;background:var(--su-surface-sunken);display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;color:var(--su-text-secondary);">RM</span>
        <span style="line-height:1.25;flex:1;"><span style="display:block;font-size:12px;font-weight:500;">Robson</span><span style="display:block;font-size:11px;color:var(--su-text-muted);">Administrador</span></span>
        <i class="ti ti-logout" style="color:var(--su-text-muted);"></i>
      </div>
      <div style="padding:0 12px 12px;text-align:center;font-size:10px;color:var(--su-text-muted);">v1.0.3</div>
    </aside>

    <div class="main">
      <header class="su-topbar">
        <div style="flex:1;">
          <div class="su-breadcrumb" id="crumb">Início <span>/</span> Clientes</div>
          <div style="font-size:16px;font-weight:600;" id="crumb-title">Clientes</div>
        </div>
        <button class="su-iconbtn" aria-label="Alternar tema" onclick="var h=document.documentElement;h.dataset.theme=h.dataset.theme==='dark'?'light':'dark';"><i class="ti ti-moon"></i></button>
      </header>

      <!-- LISTA -->
      <div class="content" id="listView">
        <div class="su-table-card">
          <div class="toolbar" id="normalbar">
            <span style="font-size:15px;font-weight:600;flex:1;">Clientes</span>
            <span class="field-search"><i class="ti ti-search"></i>Buscar</span>
            <button class="su-btn su-btn--secondary su-btn--sm"><i class="ti ti-filter"></i>Filtros</button>
            <button class="su-btn su-btn--primary su-btn--sm" onclick="showForm('Novo cliente')"><i class="ti ti-plus"></i>Novo cliente</button>
          </div>
          <div class="bulkbar" id="bulkbar">
            <span style="font-weight:500;"><i class="ti ti-square-check" style="color:var(--su-action);"></i> <span id="count">0 selecionados</span></span>
            <span class="act"><i class="ti ti-mail"></i>Cobrar</span>
            <span class="act"><i class="ti ti-download"></i>Exportar</span>
            <span class="act dz"><i class="ti ti-trash"></i>Excluir</span>
            <span class="act" style="margin-left:auto;color:var(--su-text-muted);" onclick="clearSel()"><i class="ti ti-x"></i>Limpar</span>
          </div>
          <table class="su-table">
            <thead>
              <tr>
                <th style="width:34px;padding-left:16px;"><i class="ti ti-square" id="all" style="cursor:pointer;color:var(--su-text-muted);font-size:15px;"></i></th>
                <th>Cliente <i class="ti ti-chevron-down" style="font-size:12px;"></i></th>
                <th>Status</th>
                <th class="num">Total</th>
                <th style="width:44px;"></th>
              </tr>
            </thead>
            <tbody id="rows"></tbody>
          </table>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:11px 16px;border-top:1px solid var(--su-border-subtle);font-size:12px;color:var(--su-text-secondary);">
            <span>1–5 de 1.902</span>
            <span class="su-pagination">
              <span class="su-page su-page--nav"><i class="ti ti-chevron-left"></i></span>
              <span class="su-page su-page--active">1</span><span class="su-page">2</span><span class="su-page">3</span>
              <span class="su-page su-page--nav"><i class="ti ti-chevron-right"></i></span>
            </span>
          </div>
        </div>
      </div>

      <!-- WIZARD DE CADASTRO -->
      <div class="content hidden" id="formView">
        <div class="form-page">
          <div class="form-head">
            <button class="su-iconbtn" aria-label="Voltar à lista" onclick="showList()"><i class="ti ti-arrow-left"></i></button>
            <div style="flex:1;"><div style="font-size:18px;font-weight:600;" id="form-title">Novo cliente</div><div style="font-size:13px;color:var(--su-text-secondary);">Preencha em etapas.</div></div>
          </div>

          <div class="su-card" style="padding:0;">
            <div class="su-stepper" id="stepper" style="padding:20px 24px;border-bottom:1px solid var(--su-border-subtle);"></div>

            <div style="padding:24px;">
              <div class="pane on" data-p="1">
                <div class="su-form-section__title">Dados pessoais</div>
                <div class="su-form-grid">
                  <div class="su-field su-form-grid--full"><label class="su-field__label">Nome completo</label><input class="su-input" placeholder="Nome do cliente"></div>
                  <div class="su-field"><label class="su-field__label">CPF / CNPJ</label><input class="su-input" placeholder="000.000.000-00"></div>
                  <div class="su-field"><label class="su-field__label">Data de nascimento</label><input class="su-input" type="date"></div>
                  <div class="su-field"><label class="su-field__label">RG</label><input class="su-input" placeholder="00.000.000-0"></div>
                  <div class="su-field"><label class="su-field__label">Profissão</label><input class="su-input" placeholder="Profissão"></div>
                </div>
              </div>
              <div class="pane" data-p="2">
                <div class="su-form-section__title">Contato</div>
                <div class="su-form-grid">
                  <div class="su-field"><label class="su-field__label">E-mail</label><input class="su-input" placeholder="nome@empresa.com"></div>
                  <div class="su-field">
                    <label class="su-field__label">Telefone</label>
                    <div class="su-phoneinput">
                      <button class="su-phoneinput__country" type="button" onclick="return false">🇧🇷 +55 <i class="ti ti-chevron-down" style="font-size:13px;color:var(--su-text-muted);"></i></button>
                      <input class="su-phoneinput__input" placeholder="27 99999-8888">
                    </div>
                  </div>
                </div>
              </div>
              <div class="pane" data-p="3">
                <div class="su-form-section__title">Endereço</div>
                <div class="su-form-grid">
                  <div class="su-field"><label class="su-field__label">CEP</label><input class="su-input" placeholder="00000-000"></div>
                  <div class="su-field"><label class="su-field__label">Cidade</label><input class="su-input" placeholder="Cidade"></div>
                  <div class="su-field su-form-grid--full"><label class="su-field__label">Endereço</label><input class="su-input" placeholder="Rua, número, complemento"></div>
                  <div class="su-field"><label class="su-field__label">Bairro</label><input class="su-input" placeholder="Bairro"></div>
                  <div class="su-field"><label class="su-field__label">UF</label><select class="su-select"><option>ES</option><option>SP</option><option>RJ</option></select></div>
                </div>
              </div>
              <div class="pane" data-p="4">
                <div class="su-form-section__title">Plano e cobrança</div>
                <div class="su-form-grid">
                  <div class="su-field"><label class="su-field__label">Plano</label><select class="su-select"><option>Vitalício</option><option>Mensal</option></select></div>
                  <div class="su-field"><label class="su-field__label">Dia de vencimento</label><input class="su-input" inputmode="numeric" placeholder="10"></div>
                  <div class="su-field su-form-grid--full"><label class="su-field__label">Observações</label><textarea class="su-input" placeholder="Opcional"></textarea></div>
                </div>
              </div>
            </div>

            <div class="su-form-actions" style="padding:16px 24px;border-top:1px solid var(--su-border-subtle);justify-content:space-between;">
              <button class="su-btn su-btn--secondary" id="prevBtn" onclick="prevStep()"><i class="ti ti-x"></i>Cancelar</button>
              <button class="su-btn su-btn--primary" id="nextBtn" onclick="nextStep()">Próximo <i class="ti ti-arrow-right"></i></button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    /* ---- DataTable (lista) ---- */
    var data = [
      {n:"Marina Alves", s:"Ativo", k:"success", v:"R$ 3.240"},
      {n:"Carlos Nogueira", s:"Pendente", k:"warning", v:"R$ 1.980"},
      {n:"Bianca Ferraz", s:"Inadimplente", k:"danger", v:"R$ 610"},
      {n:"Diego Prado", s:"Ativo", k:"success", v:"R$ 5.120"},
      {n:"Helena Costa", s:"Ativo", k:"success", v:"R$ 2.700"}
    ];
    var sel = new Set(), rows = document.getElementById('rows');
    var menu = '<div class="su-menu"><div class="su-menu__item" onclick="showForm(\'Editar cliente\')"><i class="ti ti-eye"></i>Ver detalhe</div><div class="su-menu__item" onclick="showForm(\'Editar cliente\')"><i class="ti ti-edit"></i>Editar</div><div class="su-menu__item"><i class="ti ti-mail"></i>Enviar cobrança</div><div class="su-menu__sep"></div><div class="su-menu__item su-menu__item--danger"><i class="ti ti-trash"></i>Excluir</div></div>';
    data.forEach(function(d,i){
      var tr = document.createElement('tr'); tr.dataset.i = i;
      tr.innerHTML = '<td style="padding-left:16px;"><i class="ti ti-square ck" data-ck="'+i+'" style="cursor:pointer;color:var(--su-text-muted);font-size:15px;"></i></td>'+
        '<td>'+d.n+'</td><td><span class="su-badge su-badge--'+d.k+'">'+d.s+'</span></td>'+
        '<td class="num">'+d.v+'</td>'+
        '<td class="row-menu"><button class="su-iconbtn" data-kb="'+i+'" aria-label="Ações"><i class="ti ti-dots"></i></button>'+menu+'</td>';
      rows.appendChild(tr);
    });
    var normalbar = document.getElementById('normalbar'), bulkbar = document.getElementById('bulkbar'), count = document.getElementById('count'), all = document.getElementById('all');
    function render(){
      var n = sel.size;
      normalbar.style.display = n>0 ? 'none' : 'flex';
      bulkbar.style.display = n>0 ? 'flex' : 'none';
      count.textContent = n + (n===1 ? ' selecionado' : ' selecionados');
      document.querySelectorAll('#rows tr').forEach(function(tr){
        var i = +tr.dataset.i, on = sel.has(i);
        tr.classList.toggle('selrow', on);
        var ck = tr.querySelector('.ck'); ck.className = 'ti ck ' + (on ? 'ti-square-check' : 'ti-square'); ck.style.color = on ? 'var(--su-action)' : 'var(--su-text-muted)';
      });
      all.className = 'ti ' + (sel.size===data.length ? 'ti-square-check' : (sel.size>0 ? 'ti-square-minus' : 'ti-square'));
      all.style.color = sel.size>0 ? 'var(--su-action)' : 'var(--su-text-muted)';
    }
    function clearSel(){ sel.clear(); render(); }
    function closeMenus(){ document.querySelectorAll('.row-menu.open').forEach(function(m){ m.classList.remove('open'); }); }

    /* ---- Wizard ---- */
    var steps = ['Dados', 'Contato', 'Endereço', 'Cobrança'], cur = 1, stepper = document.getElementById('stepper');
    function drawStepper(){
      var html = '';
      steps.forEach(function(label, idx){
        var n = idx + 1, cls = n < cur ? 'su-step su-step--done' : (n === cur ? 'su-step su-step--current' : 'su-step');
        var dot = n < cur ? '<i class="ti ti-check"></i>' : n;
        html += '<div class="'+cls+'"><span class="su-step__dot">'+dot+'</span><span class="su-step__label">'+label+'</span></div>';
        if (n < steps.length) html += '<span class="su-step__line'+(n < cur ? ' su-step__line--done' : '')+'"></span>';
      });
      stepper.innerHTML = html;
    }
    function showStep(){
      drawStepper();
      document.querySelectorAll('#formView .pane').forEach(function(p){ p.classList.toggle('on', +p.dataset.p === cur); });
      var prev = document.getElementById('prevBtn'), next = document.getElementById('nextBtn');
      prev.innerHTML = cur === 1 ? '<i class="ti ti-x"></i>Cancelar' : '<i class="ti ti-arrow-left"></i>Voltar';
      next.innerHTML = cur === steps.length ? '<i class="ti ti-check"></i>Salvar cliente' : 'Próximo <i class="ti ti-arrow-right"></i>';
    }
    function nextStep(){ if (cur < steps.length) { cur++; showStep(); } else { showList(); } }
    function prevStep(){ if (cur > 1) { cur--; showStep(); } else { showList(); } }
    function showForm(title){ document.getElementById('form-title').textContent = title; document.getElementById('crumb').innerHTML = 'Início <span>/</span> Clientes <span>/</span> ' + title; document.getElementById('crumb-title').textContent = title; cur = 1; showStep(); document.getElementById('listView').classList.add('hidden'); document.getElementById('formView').classList.remove('hidden'); closeMenus(); window.scrollTo(0,0); }
    function showList(){ document.getElementById('crumb').innerHTML = 'Início <span>/</span> Clientes'; document.getElementById('crumb-title').textContent = 'Clientes'; document.getElementById('formView').classList.add('hidden'); document.getElementById('listView').classList.remove('hidden'); }

    document.addEventListener('click', function(e){
      var ck = e.target.closest('[data-ck]');
      if(ck){ var i=+ck.dataset.ck; sel.has(i)?sel.delete(i):sel.add(i); render(); return; }
      if(e.target.closest('#all')){ if(sel.size===data.length) sel.clear(); else data.forEach(function(_,i){sel.add(i);}); render(); return; }
      var kb = e.target.closest('[data-kb]');
      if(kb){ var m=kb.closest('.row-menu'); var wasOpen=m.classList.contains('open'); closeMenus(); if(!wasOpen)m.classList.add('open'); e.stopPropagation(); return; }
      if(!e.target.closest('.su-menu')) closeMenus();
    });
    render();
  </script>
</body>
</html>
