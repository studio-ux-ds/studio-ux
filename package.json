{
  "name": "studio-ux",
  "version": "1.1.15",
  "private": true,
  "description": "Studio UX — Design System + plataforma. Monorepo dos pacotes publicáveis (tokens, components, mobile, react, react-native, icons, cli).",
  "workspaces": [
    "packages/tokens",
    "packages/components",
    "packages/mobile",
    "packages/react",
    "packages/react-native",
    "packages/icons",
    "packages/cli"
  ],
  "author": "Robson Marques <robson.marques.jr@gmail.com>",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "studio": "tools/cli/studio.mjs"
  },
  "scripts": {
    "studio": "node packages/cli/studio.mjs",
    "version:all": "node scripts/set-version.mjs",
    "publish:all": "npm publish --workspaces --access restricted",
    "pack:all": "npm pack --workspaces --pack-destination ./dist-packs",
    "create": "node packages/cli/generator/generate.mjs",
    "generate": "node packages/cli/generator/templates.mjs",
    "audit": "node packages/cli/certification/certify.mjs",
    "build:icons": "node packages/icons/build-icons.mjs",
    "export:tokens": "node packages/cli/exporters/export-tokens.mjs",
    "lint": "node packages/cli/linter/lint.mjs",
    "check": "node scripts/check-packages.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.14",
    "vite": "^5.4.19"
  }
}
