{
  "name": "studio-ux",
  "version": "1.1.10",
  "private": true,
  "description": "Studio UX — Design System + plataforma. Monorepo dos pacotes publicáveis (tokens, components, mobile, react, react-native, icons).",
  "workspaces": [
    "packages/tokens",
    "packages/components",
    "packages/mobile",
    "packages/react",
    "packages/react-native",
    "packages/icons"
  ],
  "author": "Robson Marques <robson.marques.jr@gmail.com>",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "studio": "tools/cli/studio.mjs"
  },
  "scripts": {
    "studio": "node tools/cli/studio.mjs",
    "version:all": "node scripts/set-version.mjs",
    "publish:all": "npm publish --workspaces --access restricted",
    "pack:all": "npm pack --workspaces --pack-destination ./dist-packs",
    "create": "node tools/generator/generate.mjs",
    "generate": "node tools/generator/templates.mjs",
    "build:icons": "node packages/icons/build-icons.mjs",
    "export:tokens": "node tools/exporters/export-tokens.mjs",
    "lint": "node tools/linter/lint.mjs",
    "check": "node scripts/check-packages.mjs"
  }
}
