{
  "name": "@studio-ux/react",
  "version": "1.0.14",
  "description": "Adapter React sobre o Studio UX (embrulha as classes .su-* — runtime descartável).",
  "type": "module",
  "main": "index.js",
  "module": "index.js",
  "exports": {
    ".": "./index.js",
    "./mobile": "./mobile.js"
  },
  "files": [
    "index.js",
    "mobile.js",
    "*.jsx",
